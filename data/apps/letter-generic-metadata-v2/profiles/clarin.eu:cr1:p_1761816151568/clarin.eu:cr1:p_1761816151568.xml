<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ComponentSpec isProfile="true" CMDVersion="1.2" CMDOriginalVersion="1.2" xsi:noNamespaceSchemaLocation="https://infra.clarin.eu/CMDI/1.x/xsd/cmd-component.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<Header>
		<ID>clarin.eu:cr1:p_1761816151568</ID>
		<Name>Place</Name>
		<Description>For "authorized" place names.</Description>
		<Status>development</Status>
	</Header>
	<Component name="Place" ConceptLink="http://www.cidoc-crm.org/cidoc-crm/E53_Place" CardinalityMin="1" CardinalityMax="1">
		<Component name="Identifiers" ComponentRef="clarin.eu:cr1:c_1761816151559" ConceptLink="http://www.cidoc-crm.org/cidoc-crm/E42_Identifier" CardinalityMin="1" CardinalityMax="1">
			<Documentation>-&gt;P1-&gt;E42[1_1]-&gt;P190-&gt;rdf:Literal. Internal note: for Letters (profile v2), the URI should be mapped to: https://lod.academy/cer/vocab/ontology#21_Identifier</Documentation>
			<Element name="identifierType" ConceptLink="http://purl.org/dc/terms/type" CardinalityMin="1" CardinalityMax="1" cue:DisplayPriority="1" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
				<Documentation>The type/scheme of identifier (e.g., "Wikidata QID", "VIAF", "project local"</Documentation>
				<ValueScheme>
					<Vocabulary>
						<enumeration>
							<item ConceptLink="" AppInfo="">CERL</item>
							<item ConceptLink="" AppInfo="">EMLO</item>
							<item ConceptLink="http://id.loc.gov/ontologies/bibframe/Local" AppInfo="">LocalIdentifier</item>
							<item ConceptLink="" AppInfo="">NODEGOAT</item>
							<item ConceptLink="https://www.openstreetmap.org/relation" AppInfo="">OpenStreetMaps</item>
							<item ConceptLink="" AppInfo="">Shelfmark</item>
							<item ConceptLink="https://viaf.org" AppInfo="Virtual International Authority File">VIAF</item>
							<item ConceptLink="https://www.wikidata.org" AppInfo="">Wikidata</item>
						</enumeration>
					</Vocabulary>
				</ValueScheme>
			</Element>
			<Element name="identifierValue" ConceptLink="http://purl.org/dc/terms/identifier" ValueScheme="string" CardinalityMin="1" CardinalityMax="1" cue:DisplayPriority="2" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
				<Documentation>Add the identifier's label (e.g., the shelfmark)</Documentation>
			</Element>
			<Element name="identifierUri" ConceptLink="https://schema.org/sameAs" ValueScheme="anyURI" CardinalityMin="0" CardinalityMax="1" cue:DisplayPriority="3" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
				<Documentation>Persistent identifier (optional): If the object has a permanent identifier (e.g., a URN, DOI, or handle), enter the full IRI here (e.g., https://resolver.staatsbibliothek-berlin.de/SBB00019E8400000003). It does not need to be resolvable. If it is OpenStreetMaps: Enter the URI from OpenStreetMap API. You can search directly in OpenStreetMaps and paste the URI here. The URI has to have this format, for example: https://www.openstreetmap.org/relation/214885 (note the type in the middle: relation, node, way)</Documentation>
			</Element>
		</Component>
		<Component name="PlaceType" ConceptLink="http://www.cidoc-crm.org/cidoc-crm/E55_Type" CardinalityMin="1" CardinalityMax="1">
			<Documentation>For the type of place. Preferably using GeoNames feature classes (e.g., P.PPL for populated place: https://www.geonames.org/ontology#P.PPL) </Documentation>
			<Element name="label" ValueScheme="string" CardinalityMin="1" CardinalityMax="1" cue:DisplayPriority="1" xmlns:cue="http://www.clarin.eu/cmd/cues/1"/>
			<Element name="uri" ValueScheme="anyURI" CardinalityMin="1" CardinalityMax="1" cue:DisplayPriority="2" xmlns:cue="http://www.clarin.eu/cmd/cues/1"/>
		</Component>
		<Component name="PlaceName" CardinalityMin="1" CardinalityMax="1">
			<Element name="preferredName" ValueScheme="string" CardinalityMin="1" CardinalityMax="1" cue:DisplayPriority="1" xmlns:cue="http://www.clarin.eu/cmd/cues/1"/>
			<Element name="alternativeName" ValueScheme="string" CardinalityMin="0" CardinalityMax="unbounded" cue:DisplayPriority="2" xmlns:cue="http://www.clarin.eu/cmd/cues/1"/>
		</Component>
	</Component>
</ComponentSpec>
