        <list>
          <nr>
            <xpath>replace(//*:MdSelfLink,'unl://','')</xpath>
            <label>nr</label>
            <sort>true</sort>
            <filter>true</filter>
          </nr>
          <name>
            <xpath>string(//cmdp:PlaceName/cmdp:preferredName)</xpath>
            <label>preferred name</label>
            <sort>true</sort>
            <filter>true</filter>
          </name>
        </list>
      </place>
    </prof>
    <html>
      <style>serenissima.css</style>
    </html>
  </app>
</config>
